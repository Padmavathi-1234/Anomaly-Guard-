# ==========================================
# AnomalyGuard Environment Variables
# ==========================================
# Instructions: Copy this file to .env and
# replace the example values with your actual
# sensitive credentials. Do NOT commit .env
# to version control.

# OpenAI API endpoint
API_BASE_URL=https://api.openai.com/v1

# LLM model identifier for inference
MODEL_NAME=gpt-4o-mini

# Hugging Face or OpenAI API key
HF_TOKEN=your_token_here_do_not_commit

# Environment URL for the inference script
ENV_URL=http://localhost:8000
